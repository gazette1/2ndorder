{
  "name": "adoption-chain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Idea-generation engine: seed thesis to ranked under-covered small-cap beneficiaries with auditable thesis drafts.",
  "scripts": {
    "stage": "tsx src/run.ts",
    "dry-run": "tsx src/run.ts all",
