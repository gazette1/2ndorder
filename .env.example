# Corollary production environment. Copy to the host's env settings; never commit real values.

# Reasoning models (DeepSeek via the OpenAI-compatible API)
LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=rotate-me-and-set-here

# Sessions: any long random string; tokens are HMAC-signed with it.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Access control: comma-separated emails allowed to sign in. Empty = open pilot.
ALLOWED_EMAILS=pm@examplefund.com,analyst@examplefund.com

# Spend control: model runs (scenarios, articles, drills, counters, cards) per email per day.
RUNS_PER_DAY=12

# data.gov key (free at api.data.gov): raises openFDA rate limits, required for
# FCC ECFS docket checks. Optional; FDA runs keyless and ECFS is skipped without it.
DATA_GOV_API_KEY=

# Census key (free at api.census.gov/data/key_signup.html, separate from data.gov):
# unlocks the County Business Patterns industry-size anchor. Optional.
CENSUS_API_KEY=

PORT=8787

# Google sign-in (optional): OAuth client id from console.cloud.google.com.
# Create an OAuth 2.0 Client ID (Web application), add the site origin to
# Authorized JavaScript origins. No client secret needed (ID-token flow).
GOOGLE_CLIENT_ID=
